<script>
/* ========================= HERO SLIDER ========================= */
let currentSlide = 0;
const slides     = document.querySelectorAll('.slide');
const indicators = document.querySelectorAll('.indicator');
let slideInterval;

function showSlide(index) {
    slides.forEach((s, i) => {
        s.classList.remove('active');
        if (indicators[i]) indicators[i].classList.remove('active');
    });
    currentSlide = (index + slides.length) % slides.length;
    slides[currentSlide].classList.add('active');
    if (indicators[currentSlide]) indicators[currentSlide].classList.add('active');
}
function changeSlide(dir)  { showSlide(currentSlide + dir); resetSlideInterval(); }
function goToSlide(i)      { showSlide(i);                  resetSlideInterval(); }
function resetSlideInterval() {
    clearInterval(slideInterval);
    slideInterval = setInterval(() => showSlide(currentSlide + 1), 5000);
}
slideInterval = setInterval(() => showSlide(currentSlide + 1), 5000);
document.addEventListener("visibilitychange", () => {
    document.hidden ? clearInterval(slideInterval) : resetSlideInterval();
});

/* ========================= DEALS SLIDER ========================= */
function scrollDeals(dir) {
    const c = document.getElementById("dealsSlider");
    if (c) c.scrollBy({ left: dir * 370, behavior: "smooth" });
}

/* ========================= SORT MENU ========================= */
function toggleSortMenu() {
    const menu = document.getElementById("sortMenu");
    const btn  = document.querySelector(".sort-btn");
    if (menu.classList.contains("show")) { menu.classList.remove("show"); return; }
    const rect = btn.getBoundingClientRect();
    menu.style.top  = (rect.bottom + 8) + "px";
    menu.style.left = rect.left + "px";
    menu.classList.add("show");
}
window.addEventListener("click", e => {
    const btn  = document.querySelector(".sort-btn");
    const menu = document.getElementById("sortMenu");
    if (menu && btn && !menu.contains(e.target) && !btn.contains(e.target))
        menu.classList.remove("show");
});
document.querySelector(".apply-sort").addEventListener("click", () => {
    const sel = document.querySelector('.sort-menu input[name="sort"]:checked');
    const con = document.querySelector(".restaurant-container");
    if (!sel || !con) return;
    const cards = Array.from(con.querySelectorAll(".card"));
    const label = sel.parentElement.textContent.trim();
    if (label.includes("Delivery")) {
        cards.sort((a, b) => (parseInt(a.querySelector(".rating-time")?.innerText.split("•")[1]) || 99) -
                             (parseInt(b.querySelector(".rating-time")?.innerText.split("•")[1]) || 99));
    } else if (label.includes("Rating")) {
        cards.sort((a, b) => (parseFloat(b.querySelector(".rating-time")?.innerText.split("⭐")[1]) || 0) -
                             (parseFloat(a.querySelector(".rating-time")?.innerText.split("⭐")[1]) || 0));
    }
    cards.forEach(c => con.appendChild(c));
    document.getElementById("sortMenu").classList.remove("show");
});

/* ========================= FILTER PANEL ========================= */
const filterBtn     = document.getElementById("filter");
const filterPanel   = document.getElementById("filterPanel");
const filterOverlay = document.getElementById("filterOverlay");

filterBtn.addEventListener("click", () => {
    filterPanel.classList.add("show");
    filterOverlay.classList.add("show");
    document.body.classList.add("filter-open");
    showContent('content1');
    setActiveSidebar('sortButton');
});
function closeFilterPanel() {
    filterPanel.classList.remove("show");
    filterOverlay.classList.remove("show");
    document.body.classList.remove("filter-open");
}
document.addEventListener("keydown", e => {
    if (e.key === "Escape" && filterPanel.classList.contains("show")) closeFilterPanel();
});

/* ========================= SIDEBAR TABS ========================= */
function showContent(id) {
    document.querySelectorAll(".filter-content").forEach(c => c.classList.remove("show"));
    const el = document.getElementById(id); if (el) el.classList.add("show");
}
function setActiveSidebar(id) {
    document.querySelectorAll(".filter-sidebar div").forEach(d => d.classList.remove("active"));
    const el = document.getElementById(id); if (el) el.classList.add("active");
}
const sidebarMap = {
    sortButton:"content1", deliveryButton:"content2", exploreButton:"content3",
    cuisineButton:"content4", ratingsButton:"content5", vegButton:"content6",
    offerButton:"content7", costButton:"content8"
};
Object.keys(sidebarMap).forEach(id => {
    const btn = document.getElementById(id);
    if (btn) btn.addEventListener("click", () => { showContent(sidebarMap[id]); setActiveSidebar(id); });
});

const checkboxes    = document.querySelectorAll('.filter-checkbox');
const filterActions = document.getElementById('filterActions');
checkboxes.forEach(cb => {
    cb.addEventListener('change', () => {
        filterActions.style.display = Array.from(checkboxes).some(c => c.checked) ? 'flex' : 'none';
    });
});

/* ========================= APPLY / CLEAR ========================= */
function clearFilters() {
    checkboxes.forEach(cb => cb.checked = false);
    filterActions.style.display = 'none';
    if (isRatingFilterActive) resetRatingFilter();
    if (isFastDeliveryActive) resetFastDeliveryFilter();
    if (isoffer)              resetOfferFilter();
    if (isexplore)            resetExploreFilter();
    closeFilterPanel();
}
function applyFilters() {
    document.getElementById('rating4Checkbox').checked   ? applyRatingFilter()       : (isRatingFilterActive && resetRatingFilter());
    document.getElementById('deliveryCheckbox').checked  ? applyFastDeliveryFilter() : (isFastDeliveryActive && resetFastDeliveryFilter());
    document.getElementById('offerCheckbox').checked     ? applyOfferFilter()        : (isoffer             && resetOfferFilter());
    document.getElementById('exploreCheckbox').checked   ? applyExploreFilter()      : (isexplore           && resetExploreFilter());
    closeFilterPanel();
}

/* ========================= FILTER COUNT ========================= */
let activeFilterCount = 0;
function updateFilterCount() {
    const el = document.getElementById('filter');
    el.innerHTML = activeFilterCount > 0
        ? `<i class="fas fa-sliders-h"></i> <span>Filters (${activeFilterCount})</span>`
        : `<i class="fas fa-sliders-h"></i> <span>Filter</span>`;
}

/* ========================= RATING FILTER ========================= */
let isRatingFilterActive = false;
function toggleRatingFilter() { isRatingFilterActive ? resetRatingFilter() : applyRatingFilter(); }
function applyRatingFilter() {
    document.querySelectorAll('.restaurant-container a').forEach(a => {
        const card = a.querySelector('.card');
        const r = parseFloat(card?.querySelector('.rating-time')?.innerText.split('⭐')[1]) || 0;
        a.style.display = r >= 4.0 ? '' : 'none';
    });
    isRatingFilterActive = true; activeFilterCount++; updateFilterCount();
    document.getElementById('ratingClose').style.display = 'inline';
    const cb = document.getElementById('rating4Checkbox'); if (cb) cb.checked = true;
    filterActions.style.display = 'flex';
}
function resetRatingFilter() {
    document.querySelectorAll('.restaurant-container a').forEach(a => a.style.display = '');
    isRatingFilterActive = false; activeFilterCount = Math.max(0, activeFilterCount-1); updateFilterCount();
    document.getElementById('ratingClose').style.display = 'none';
    const cb = document.getElementById('rating4Checkbox'); if (cb) cb.checked = false;
    if (!Array.from(checkboxes).some(c => c.checked)) filterActions.style.display = 'none';
}

/* ========================= FAST DELIVERY FILTER ========================= */
let isFastDeliveryActive = false;
function toggleFastDeliveryFilter() { isFastDeliveryActive ? resetFastDeliveryFilter() : applyFastDeliveryFilter(); }
function applyFastDeliveryFilter() {
    document.querySelectorAll('.restaurant-container a').forEach(a => {
        const card = a.querySelector('.card');
        const t = parseInt(card?.querySelector('.rating-time')?.innerText.split('•')[1]?.trim().split('-')[0]) || 999;
        a.style.display = t <= 30 ? '' : 'none';
    });
    isFastDeliveryActive = true; activeFilterCount++; updateFilterCount();
    document.getElementById('fastDeliveryClose').style.display = 'inline';
    const cb = document.getElementById('deliveryCheckbox'); if (cb) cb.checked = true;
    filterActions.style.display = 'flex';
}
function resetFastDeliveryFilter() {
    document.querySelectorAll('.restaurant-container a').forEach(a => a.style.display = '');
    isFastDeliveryActive = false; activeFilterCount = Math.max(0, activeFilterCount-1); updateFilterCount();
    document.getElementById('fastDeliveryClose').style.display = 'none';
    const cb = document.getElementById('deliveryCheckbox'); if (cb) cb.checked = false;
    if (!Array.from(checkboxes).some(c => c.checked)) filterActions.style.display = 'none';
}

/* ========================= OFFER FILTER ========================= */
let isoffer = false;
function toggleOfferFilter() { isoffer ? resetOfferFilter() : applyOfferFilter(); }
function applyOfferFilter() {
    document.querySelectorAll('.restaurant-container a').forEach(a => {
        const t = a.querySelector('.offer-badge')?.innerText || "";
        a.style.display = (t.includes("₹") || t.includes("%")) ? '' : 'none';
    });
    isoffer = true; activeFilterCount++; updateFilterCount();
    document.getElementById('offerClose').style.display = 'inline';
    const cb = document.getElementById('offerCheckbox'); if (cb) cb.checked = true;
    filterActions.style.display = 'flex';
}
function resetOfferFilter() {
    document.querySelectorAll('.restaurant-container a').forEach(a => a.style.display = '');
    isoffer = false; activeFilterCount = Math.max(0, activeFilterCount-1); updateFilterCount();
    document.getElementById('offerClose').style.display = 'none';
    const cb = document.getElementById('offerCheckbox'); if (cb) cb.checked = false;
    if (!Array.from(checkboxes).some(c => c.checked)) filterActions.style.display = 'none';
}

/* ========================= EXPLORE FILTER ========================= */
let isexplore = false;
function toggleExploreFilter() { isexplore ? resetExploreFilter() : applyExploreFilter(); }
function applyExploreFilter() {
    document.querySelectorAll('.restaurant-container a').forEach(a => {
        const t = a.querySelector('.rating-time')?.innerText || "";
        a.style.display = !t.includes("⭐") ? '' : 'none';
    });
    isexplore = true; activeFilterCount++; updateFilterCount();
    document.getElementById('exploreClose').style.display = 'inline';
    const cb = document.getElementById('exploreCheckbox'); if (cb) cb.checked = true;
    filterActions.style.display = 'flex';
}
function resetExploreFilter() {
    document.querySelectorAll('.restaurant-container a').forEach(a => a.style.display = '');
    isexplore = false; activeFilterCount = Math.max(0, activeFilterCount-1); updateFilterCount();
    document.getElementById('exploreClose').style.display = 'none';
    const cb = document.getElementById('exploreCheckbox'); if (cb) cb.checked = false;
    if (!Array.from(checkboxes).some(c => c.checked)) filterActions.style.display = 'none';
}
</script>

