<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/user/sign.css">
</head>
<body>

    <!-- FLASH: fixed top-right, above everything -->
    <div class="flash-container">
        <%- include("../includes/flash") %>
    </div>

    <!-- LEFT PANEL -->
    <div class="panel-left">
        <div class="candle-glow"></div>
        <div class="panel-left-content">
            <div class="brand">
                <span class="brand-icon">🍴</span>
                <span class="brand-name">DINE<span>aus</span></span>
            </div>
            <div class="panel-hero">
                <div class="elite-badge">Elite Member Access</div>
                <h2>Elevate Your <em>Dining</em><br>Experience</h2>
                <p>Join the most exclusive culinary circle. From hidden gems to Michelin-starred icons, your seat at the finest tables awaits.</p>
            </div>
            <div class="panel-features">
                <div class="feat-card">
                    <div class="feat-icon">🪑</div>
                    <div class="feat-text"><strong>Premium Table Bookings</strong><span>Priority access 24/7</span></div>
                </div>
                <div class="feat-card">
                    <div class="feat-icon">🛵</div>
                    <div class="feat-text"><strong>Gourmet Delivery</strong><span>Fine dining at your door</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL — original HTML untouched -->
    <div class="container">
    <h1>Sign up
        <a href="/home" class="wrong-icon">
            <i class="fa-solid fa-xmark"></i>
        </a>
    </h1>
    <p class="form-sub">Join DINEaus today and start your journey.</p>
    <form method="POST" action="/sign">
        <div class="input-group">
        <input placeholder="First name" type="text" name="firstname">
        <br><br>
        <input placeholder="Last name" type="text" name="lastname">
        <br><br>
        <input type="email" id="email" name="email" placeholder="Enter Email">
        <br><br>
        <input placeholder="Phone Number" type="number" name="number">
        <br><br>
        <input type="password" placeholder="password" name="password">
        <br><br>
        <input placeholder="Confirm password" name="confirm">
        <br><br>
        <button class="btn"><span>Sign up</span></button>
        </div>
    </form>
   <div class="links"> <p>Already have an account? <a href="http://localhost:8080/login"><b>Log in</a></b></p></div>
</div>

</body>
</html>
