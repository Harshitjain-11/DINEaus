
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Partner with Dineous</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/restaurant/dineous-partner.css">
</head>
<body>
<%- include("../includes/flash") %>
  <!-- ════════ HERO ════════ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div class="hero-inner">

      <!-- Left: headline -->
      <div class="hero-left">
        <div class="hero-eyebrow">
          <span class="eyebrow-dot"></span>
          Restaurant Partner Programme
        </div>

        <h1 class="hero-h1">
          Reach customers<br>
          <span class="accent">far beyond</span><br>
          your doors
        </h1>

        <p class="hero-sub">
          Join thousands of restaurants on Dineous and grow your business with
          our powerful delivery network, real-time analytics, and dedicated partner support.
        </p>

        <div class="stats">
          <div class="stat">
            <span class="stat-num">50K+</span>
            <span class="stat-label">Partner Restaurants</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-num">2M+</span>
            <span class="stat-label">Monthly Orders</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-num">24hr</span>
            <span class="stat-label">Go-Live Time</span>
          </div>
        </div>
      </div>

      <!-- Right: form card -->
      <div class="form-card">
        <span class="card-badge">🚀 Get Started Free</span>
        <h2 class="card-title">Register your restaurant</h2>
        <p class="card-sub">Enter your details below to begin onboarding</p>

        <div class="divider">
          <div class="div-line"></div>
          <div class="div-dot"></div>
          <div class="div-line"></div>
        </div>

        <div class="input-wrap">
          <span class="input-icon">📱</span>
          <input type="text" placeholder="Restaurant ID / Mobile number" />
        </div>

        <a href="/resturantinformation" class="btn-continue">Continue →</a>

        <p class="terms">
          By continuing, I agree to Dineous&nbsp;<a href="#">Terms &amp; Conditions</a>
          and <a href="#">Privacy Policy</a>
        </p>
      </div>

    </div>
  </section>

  <!-- ════════ INFO SECTION ════════ -->
  <section>
    <div class="info-section">

      <!-- Steps card -->
      <div class="info-card">
        <div class="ic-num">01</div>
        <h3 class="ic-title">Get delivery-ready in 3 easy steps</h3>
        <p class="ic-sub">Your restaurant can go live within 24 hours</p>

        <ol class="steps">
          <li>
            <span class="step-num">1</span>
            Install the Dineous Owner App on your device
          </li>
          <li>
            <span class="step-num">2</span>
            Login or Register using your phone number
          </li>
          <li>
            <span class="step-num">3</span>
            Enter restaurant details and go live!
          </li>
        </ol>
      </div>

      <!-- Documents card -->
      <div class="info-card">
        <div class="ic-num">02</div>
        <h3 class="ic-title">Documents you'll need</h3>
        <p class="ic-sub">Keep these handy for a smooth onboarding process</p>

        <ul class="docs">
          <li>
            <span class="doc-left"><span class="doc-icon">📄</span> FSSAI License copy</span>
            <a href="#">Apply Here</a>
          </li>
          <li>
            <span class="doc-left"><span class="doc-icon">🍽️</span> Your Restaurant menu</span>
          </li>
          <li>
            <span class="doc-left"><span class="doc-icon">🏦</span> Bank account details</span>
          </li>
          <li>
            <span class="doc-left"><span class="doc-icon">🧾</span> GSTIN number</span>
            <a href="#">Apply Here</a>
          </li>
          <li>
            <span class="doc-left"><span class="doc-icon">🪪</span> PAN card copy</span>
          </li>
        </ul>
      </div>

    </div>
  </section>
</body>
</html>