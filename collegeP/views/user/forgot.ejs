<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - DINEaus</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/user/forgot.css">
</head>
<body>

    <!-- LEFT PANEL -->
    <div class="panel-left">
        <div class="candle-glow"></div>
        <div class="panel-left-content">
            <div class="brand">
                <span class="brand-icon">🍴</span>
                <span class="brand-name">DINE<span>aus</span></span>
            </div>
            <div class="panel-hero">
                <div class="panel-badge">Account Recovery</div>
                <h2>Recover Your <em>Access</em></h2>
                <p>We'll help you get back to your table. Enter your email and we'll send a reset link instantly.</p>
            </div>
            <div class="panel-features">
                <div class="feat-card">
                    <div class="feat-icon">📧</div>
                    <div class="feat-text"><strong>Email Reset</strong><span>Link sent instantly</span></div>
                </div>
                <div class="feat-card">
                    <div class="feat-icon">🔐</div>
                    <div class="feat-text"><strong>Secure Process</strong><span>Verified & protected</span></div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL — original HTML structure untouched -->
    <div class="container">
        <div class="form-icon">🔑</div>
        <div class="header">
            <h1>Forgot Password</h1>
            <p>Reset your DINEaus account password</p>
        </div>

        <div class="instructions">
            <ul>
                <li>Please enter the email address associated with your member profile below, which you provided at the time of registration and click on submit button.</li>
                <li>A link to reset your password will immediately be sent to the email address.</li>
                <li>Open your email account and use the link to reset your password.</li>
            </ul>
        </div>

        <form method="POST" action="/forgot">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" class="input-field" placeholder="Enter your email address" autocomplete="off" required>
                <p class="example-text">(example: divyang@gmail.com)</p>
            </div>

            <input type="hidden" name="randomString" value="<%= randomString %>">

            <div class="captcha-section">
                <p class="captcha-title">Security Verification</p>
                <div class="captcha-display">
                    <%= randomString %>
                </div>
                <p style="color: var(--muted); font-size: .8rem; margin-bottom: 10px;">Please enter the text shown above in the box below</p>
                <textarea name="textarea" class="captcha-input" placeholder="Enter the captcha text here" rows="2" required></textarea>
            </div>

            <button type="submit" class="submit-btn">Submit Request</button>

            <div class="back-link">
                <p>Remember your password?<a href="/login">Log in</a></p>
            </div>
        </form>
    </div>

</body>
</html>