    socket.on("profileOrderUpdate", (data) => {
    console.log("🔥 order updated on profile", data);

    const box = document.getElementById("order-" + data.orderId);
    if (!box) return;

    const statusEl = box.querySelector(".order-status");
    if (statusEl) {
      statusEl.innerText = data.status.toUpperCase();
    }

    // remove cancel button if order sent
    if (data.status !== "scheduled") {
      const cancelForm = box.querySelector(".cancel-form");
      if (cancelForm) cancelForm.remove();
    }
  });

</script>
<script>
let profileMap, profileMarker;

async function autoFillAddress(lat, lng) {
  try {
    const res = await fetch(
      `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`
    );
    const data = await res.json();
    if (!data.address) return;

    const addr = data.address;

    document.getElementById("street").value =
      addr.road || addr.suburb || "";

    document.getElementById("city").value =
      addr.city || addr.town || addr.village || "";

    document.getElementById("state").value =
      addr.state || "";

    document.getElementById("pincode").value =
      addr.postcode || "";

    document.getElementById("landmark").value =
      addr.neighbourhood || addr.hamlet || "";

  } catch (err) {
    console.log("Reverse geocode failed:", err);
  }
}

function showMap(lat, lng) {
  document.getElementById("mapLoader").style.display = "none";
  document.getElementById("profileMap").style.display = "block";

  if (!profileMap) {
    profileMap = L.map("profileMap").setView([lat, lng], 16);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19
    }).addTo(profileMap);

    profileMarker = L.marker([lat, lng], { draggable: true }).addTo(profileMap);

    profileMarker.on("dragend", () => {
  const pos = profileMarker.getLatLng();

  profileMap.panTo(pos); // ✅ map bhi marker ke saath move kare

  profileLat.value = pos.lat;
  profileLng.value = pos.lng;

  autoFillAddress(pos.lat, pos.lng); // (agar autofill laga hua hai)
});
  } else {
    profileMap.setView([lat, lng], 16);
    profileMarker.setLatLng([lat, lng]);
  }

  profileLat.value = lat;
  profileLng.value = lng;

  setTimeout(() => profileMap.invalidateSize(), 200);
}

// when Address tab opened
document.querySelector('[data-tab="address"]').addEventListener("click", () => {
  setTimeout(() => {

    if (!profileMap) {
      showMap(26.2183, 78.1828); // fallback Gwalior
    } else {
      profileMap.invalidateSize();
    }

    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(pos => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;

        profileMap.setView([lat, lng], 16);
        profileMarker.setLatLng([lat, lng]);

        profileLat.value = lat;
        profileLng.value = lng;

        autoFillAddress(lat, lng); // ✅ GPS autofill
      });
    }

  }, 150);
});
</script>

